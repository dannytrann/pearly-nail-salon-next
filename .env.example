# Salon Information
NEXT_PUBLIC_SALON_NAME=Your Salon Name
NEXT_PUBLIC_SALON_ADDRESS=Your Address
NEXT_PUBLIC_SALON_PHONE=(XXX) XXX-XXXX
NEXT_PUBLIC_SALON_EMAIL=info@yoursalon.com

# Square API Integration
# Obtain these from https://developer.squareup.com/
SQUARE_ACCESS_TOKEN=your_square_access_token
SQUARE_LOCATION_ID=your_square_location_id
SQUARE_ENVIRONMENT=production

# Feature Flags
USE_SQUARE_SERVICES=true
USE_SQUARE_BOOKINGS=true
USE_SQUARE_TECHNICIANS=true
USE_SQUARE_BUSINESS_HOURS=true
